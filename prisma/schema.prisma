// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Get a free hosted Postgres database in seconds: `npx create-db`

generator client {
  provider = "mysql"
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

// O novo molde do nosso usuário
model User {
  id       Int    @id @default(autoincrement()) // ID numérico automático
  name     String
  email    String @unique 
  password String
}